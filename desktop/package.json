{
  "name": "home-asset-management-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build:frontend": "npm --prefix ../frontend run build",
    "build:backend": "node ./scripts/build-backend.mjs",
    "build": "tsc -p tsconfig.json",
    "stage:resources": "node ./scripts/stage-resources.mjs",
    "typecheck": "tsc --pretty false --noEmit",
    "dev": "npm run build && electron-forge start",
    "package": "npm run build:frontend && npm run build:backend && npm run build && npm run stage:resources && electron-forge package",
    "make": "npm run build:frontend && npm run build:backend && npm run build && npm run stage:resources && electron-forge make"
  },
  "config": {
    "forge": "./forge.config.ts"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/shared-types": "^7.8.1",
    "@types/node": "^22.13.10",
    "electron": "^35.0.0",
    "typescript": "^5.8.2"
  }
}
